{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "title": "Account Password Manager",

  "type": "object",
  "additionalProperties": false,

  "properties": {
    "Description": {
      "type": "string"
    },

    "UserId": {
      "type": "string",
      "minLength": 6,
      "pattern": "^\\S+$"
    },

    "LoginUrl": {
      "type": "string",
      "format": "uri"
    },

    "PasswordInfo": {
      "type": "object",
      "additionalProperties": false,

      "properties": {
        "Password": {
          "type": "string",
          "minLength": 6,
          "pattern": "^\\S+$"
        },

        "StrengthNum": {
          "type": "integer"
        },

        "StrengthText": {
          "type": "string",
          "enum": [
            "very weak",
            "weak",
            "medium",
            "strong",
            "very strong"
          ]
        },

        "LastReset": {
          "type": "string",
          "format": "date"
        }
      },

      "required": [
        "Password",
        "StrengthText",
        "LastReset"
      ]
    },

    "Notes": {
      "type": "string"
    }
  },

  "required": [
    "Description",
    "UserId",
    "LoginUrl",
    "PasswordInfo"
  ]
}